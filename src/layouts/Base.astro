---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Hankyeol Kyung — agent engineer building personal and ambient AI systems.' } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const nav = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/writing', label: 'Writing' },
  { href: '/links', label: 'Links' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <a href="/" class="site-name">Hankyeol Kyung</a>
      <nav>
        {nav.map(({ href, label }) => (
          <a href={href} class:list={[{ active: isActive(href) }]}>{label}</a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>&copy; {new Date().getFullYear()} Hankyeol Kyung</footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
