---
import Base from '../layouts/Base.astro';
---

<Base
  title="Links"
  description="Find Hankyeol Kyung across GitHub, X, and Asleep."
>
  <section class="hero">
    <div class="eyebrow">Links</div>
    <h1>Public surfaces</h1>
    <p class="hero-lede">A few reliable places to find my work, writing, and day-job context.</p>
  </section>

  <div class="links-list">
    <a href="https://github.com/keenranger" rel="me">
      GitHub
      <span class="desc">Code, experiments, and the practical systems layer</span>
    </a>
    <a href="https://x.com/hankyeolkyung" rel="me">
      X / Twitter
      <span class="desc">Short-form thoughts on agents, products, and what I'm noticing</span>
    </a>
    <a href="https://asleep.ai">
      Asleep
      <span class="desc">Where I work on ambient AI and SleepHub</span>
    </a>
  </div>
</Base>
