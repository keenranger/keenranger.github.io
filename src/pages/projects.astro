---
import Base from '../layouts/Base.astro';
---

<Base title="Projects — Hankyeol Kyung">
  <h1>Projects</h1>

  <div class="project">
    <h3>SleepHub</h3>
    <span class="tag">product</span>
    <span class="tag">ambient AI</span>
    <p>
      Bedside AI system for autonomous sleep coaching and monitoring.
      Combines contactless sleep sensing with voice interaction and
      personalized health insights.
    </p>
  </div>

  <div class="project">
    <h3>Knowledge OS</h3>
    <span class="tag">personal OS</span>
    <span class="tag">markdown</span>
    <p>
      A markdown-first personal operating system built around memory, retrieval,
      and curated public expression. Turns scattered context into reusable task
      context, then publishes selected parts as this site.
    </p>
  </div>

  <div class="project">
    <h3>Agent Infrastructure</h3>
    <span class="tag">infra</span>
    <span class="tag">runtime</span>
    <p>
      Tooling for runtime correctness, memory continuity, and human-AI collaboration
      surfaces. Focused on making agents reliable enough to trust with real workflows.
    </p>
  </div>
</Base>
